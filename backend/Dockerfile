# Указываем базовый образ с SDK (тут есть компилятор и инструменты сборки)
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build

# Указываем рабочую папку внутри контейнера (как cd в консоли)
WORKDIR /src

# Копируем всё из текущей папки компьютера в рабочую папку контейнера
COPY . .

# Восстанавливаем зависимости (NuGet пакеты), которые указаны в .csproj
RUN dotnet restore

# Компилируем проект в режиме Release и сохраняем результат в папку /app/out
RUN dotnet publish -c Release -o /app/out

# Начинаем вторую стадию — берем легкий образ только для запуска (без инструментов сборки)
FROM mcr.microsoft.com/dotnet/aspnet:8.0

# Переходим в папку, где будет лежать наше приложение
WORKDIR /app

# САМАЯ ВАЖНАЯ ЧАСТЬ: копируем только скомпилированные файлы из первого образа (build)
COPY --from=build /app/out .

# Говорим Docker-у, что приложение будет слушать порт 8080
EXPOSE 8080

# Команда, которая запустит наше приложение при старте контейнера
ENTRYPOINT ["dotnet", "backend.dll"]